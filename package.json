{
  "name": "kagi-ken-mcp",
  "version": "1.3.0",
  "description": "Kagi MCP server using kagi-ken package",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "kagi-ken-mcp": "src/index.ts"
  },
  "files": [
    "src/",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --inspect src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "kagi",
    "search",
    "summarizer",
    "claude"
  ],
  "author": "Carlo Zottmann <carlo@zottmann.dev>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.1.2",
    "zod": "^3.22.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czottmann/kagi-ken-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/czottmann/kagi-ken-mcp/issues"
  },
  "homepage": "https://github.com/czottmann/kagi-ken-mcp#readme",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
