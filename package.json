{
  "name": "tobira",
  "version": "1.3.0",
  "private": true,
  "description": "Kagi CLI using a session-token client with optional MCP server mode",
  "keywords": [
    "cli",
    "claude",
    "kagi",
    "mcp",
    "search",
    "summarizer"
  ],
  "homepage": "https://github.com/evanlouie/tobira#readme",
  "bugs": {
    "url": "https://github.com/evanlouie/tobira/issues"
  },
  "license": "MIT",
  "author": "Carlo Zottmann <carlo@zottmann.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evanlouie/tobira.git"
  },
  "bin": {
    "tobira": "src/index.ts"
  },
  "files": [
    "src/",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts --help",
    "dev": "bun --inspect src/index.ts --help",
    "mcp": "bun src/index.ts mcp",
    "test:integration": "KAGI_INTEGRATION=1 bun test tests/integration",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware --type-check src/",
    "fmt": "oxfmt src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.1.2",
    "neverthrow": "^8.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260322.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {}
}
